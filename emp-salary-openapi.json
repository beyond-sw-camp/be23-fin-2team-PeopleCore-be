{
  "openapi": "3.0.3",
  "info": {
    "title": "사원급여 API",
    "description": "EmpSalaryController - 사원 급여 관리 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "paths": {
    "/pay/admin/employees": {
      "get": {
        "tags": ["사원급여"],
        "summary": "사원 급여 목록 조회",
        "description": "사원 급여 목록을 페이징으로 조회합니다. 키워드, 부서, 직원구분, 재직상태로 필터링 가능합니다.",
        "operationId": "getEmpSalaryList",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "description": "검색 키워드",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deptId",
            "in": "query",
            "required": false,
            "description": "부서 ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "empType",
            "in": "query",
            "required": false,
            "description": "직원구분 (FULL: 정규직, CONTRACT: 계약직)",
            "schema": {
              "type": "string",
              "enum": ["FULL", "CONTRACT"]
            }
          },
          {
            "name": "empStatus",
            "in": "query",
            "required": false,
            "description": "재직상태 (ACTIVE: 재직, ON_LEAVE: 휴직, RESIGNED: 퇴사)",
            "schema": {
              "type": "string",
              "enum": ["ACTIVE", "ON_LEAVE", "RESIGNED"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "페이지 번호 (0부터 시작)",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "페이지 크기",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "정렬 (예: empName,asc)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageEmpSalaryResDto"
                }
              }
            }
          }
        }
      }
    },
    "/pay/admin/employees/{empId}": {
      "get": {
        "tags": ["사원급여"],
        "summary": "사원 급여 상세 조회",
        "description": "특정 사원의 급여 상세 정보를 조회합니다.",
        "operationId": "getEmpSalaryDetail",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "empId",
            "in": "path",
            "required": true,
            "description": "사원 ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmpSalaryDetailResDto"
                }
              }
            }
          }
        }
      }
    },
    "/pay/admin/employees/{empId}/account": {
      "put": {
        "tags": ["사원급여"],
        "summary": "사원 계좌 변경",
        "description": "사원의 급여 계좌를 변경합니다.",
        "operationId": "updateEmpAccount",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "empId",
            "in": "path",
            "required": true,
            "description": "사원 ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmpAccountReqDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "성공"
          }
        }
      }
    },
    "/pay/admin/employees/{empId}/retirement-account": {
      "put": {
        "tags": ["사원급여"],
        "summary": "퇴직연금계좌 변경",
        "description": "사원의 퇴직연금 계좌를 변경합니다.",
        "operationId": "updateRetirementAccount",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "empId",
            "in": "path",
            "required": true,
            "description": "사원 ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmpRetirementAccountReqDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "성공"
          }
        }
      }
    },
    "/pay/admin/employees/{empId}/retirement-type": {
      "put": {
        "tags": ["사원급여"],
        "summary": "퇴직연금 유형 변경",
        "description": "사원의 퇴직연금 유형을 변경합니다. 회사 퇴직연금 설정이 DB_DC일 때 사용합니다.",
        "operationId": "updateRetirementType",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "empId",
            "in": "path",
            "required": true,
            "description": "사원 ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetirementTypeUpdateReqDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "성공"
          }
        }
      }
    },
    "/pay/admin/employees/expected-deductions": {
      "get": {
        "tags": ["사원급여"],
        "summary": "월급여 예상지급공제 조회",
        "description": "전체 사원의 월급여 예상 지급/공제 내역을 조회합니다.",
        "operationId": "getExpectedDeductions",
        "parameters": [
          {
            "name": "X-User-Company",
            "in": "header",
            "required": true,
            "description": "회사 ID (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExpectedDeductionSummaryResDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EmpSalaryResDto": {
        "type": "object",
        "properties": {
          "empId": { "type": "integer", "format": "int64", "description": "사원 ID" },
          "empStatus": { "type": "string", "enum": ["ACTIVE", "ON_LEAVE", "RESIGNED"], "description": "재직상태" },
          "empName": { "type": "string", "description": "사원명" },
          "deptName": { "type": "string", "description": "부서명" },
          "titleName": { "type": "string", "description": "직위명" },
          "empHireDate": { "type": "string", "format": "date", "description": "입사일" },
          "empResignDate": { "type": "string", "format": "date", "nullable": true, "description": "퇴사일" },
          "empType": { "type": "string", "enum": ["FULL", "CONTRACT"], "description": "직원구분 (정규직/계약직)" },
          "annualSalary": { "type": "number", "description": "연봉" },
          "monthlySalary": { "type": "integer", "format": "int64", "description": "월급" },
          "bankName": { "type": "string", "description": "은행명" },
          "accountNumber": { "type": "string", "description": "계좌번호" }
        }
      },
      "PageEmpSalaryResDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EmpSalaryResDto" }
          },
          "totalElements": { "type": "integer", "format": "int64", "description": "전체 요소 수" },
          "totalPages": { "type": "integer", "description": "전체 페이지 수" },
          "size": { "type": "integer", "description": "페이지 크기" },
          "number": { "type": "integer", "description": "현재 페이지 번호" },
          "first": { "type": "boolean", "description": "첫 페이지 여부" },
          "last": { "type": "boolean", "description": "마지막 페이지 여부" },
          "empty": { "type": "boolean", "description": "빈 페이지 여부" },
          "numberOfElements": { "type": "integer", "description": "현재 페이지 요소 수" }
        }
      },
      "EmpSalaryDetailResDto": {
        "type": "object",
        "properties": {
          "empId": { "type": "integer", "format": "int64", "description": "사원 ID" },
          "empName": { "type": "string", "description": "사원명" },
          "empNum": { "type": "string", "description": "사번" },
          "empEmail": { "type": "string", "description": "이메일" },
          "empStatus": { "type": "string", "enum": ["ACTIVE", "ON_LEAVE", "RESIGNED"], "description": "재직상태" },
          "deptName": { "type": "string", "description": "부서명" },
          "gradeName": { "type": "string", "description": "등급명" },
          "titleName": { "type": "string", "description": "직위명" },
          "empHireDate": { "type": "string", "format": "date", "description": "입사일" },
          "empResignDate": { "type": "string", "format": "date", "nullable": true, "description": "퇴사일" },
          "empType": { "type": "string", "enum": ["FULL", "CONTRACT"], "description": "직원구분" },
          "annualSalary": { "type": "number", "description": "연봉" },
          "monthlySalary": { "type": "integer", "format": "int64", "description": "월급" },
          "fixedPayItems": {
            "type": "array",
            "description": "고정수당 항목",
            "items": { "$ref": "#/components/schemas/ContractPayItemResDto" }
          },
          "empAccountId": { "type": "integer", "format": "int64", "description": "계좌 ID" },
          "bankName": { "type": "string", "description": "은행명" },
          "accountNumber": { "type": "string", "description": "계좌번호" },
          "accountHolder": { "type": "string", "description": "예금주" },
          "companyPensionType": { "type": "string", "enum": ["severance", "DB", "DC", "DB_DC"], "description": "회사 퇴직연금 설정" },
          "empRetirementType": { "type": "string", "enum": ["severance", "DB", "DC"], "description": "사원 퇴직연금 유형" },
          "retirementAccountId": { "type": "integer", "format": "int64", "description": "퇴직연금 계좌 ID" },
          "pensionProvider": { "type": "string", "description": "퇴직연금 운용사" },
          "retirementAccountNumber": { "type": "string", "description": "퇴직연금 계좌번호" }
        }
      },
      "ContractPayItemResDto": {
        "type": "object",
        "properties": {
          "payItemId": { "type": "integer", "format": "int64", "description": "급여항목 ID" },
          "payItemName": { "type": "string", "description": "급여항목명" },
          "amount": { "type": "integer", "description": "금액" }
        }
      },
      "EmpAccountReqDto": {
        "type": "object",
        "required": ["bankName", "accountNumber", "accountHolder", "bankCode", "verificationToken"],
        "properties": {
          "bankName": { "type": "string", "description": "은행명" },
          "accountNumber": { "type": "string", "description": "계좌번호" },
          "accountHolder": { "type": "string", "description": "예금주" },
          "bankCode": { "type": "string", "description": "은행코드 3자리 (예: 088)" },
          "verificationToken": { "type": "string", "description": "계좌검증 토큰" }
        }
      },
      "EmpRetirementAccountReqDto": {
        "type": "object",
        "required": ["retirementType", "pensionProvider"],
        "properties": {
          "retirementType": { "type": "string", "enum": ["severance", "DB", "DC"], "description": "퇴직연금 유형" },
          "pensionProvider": { "type": "string", "description": "퇴직연금 운용사" },
          "accountNumber": { "type": "string", "description": "퇴직연금 계좌번호" }
        }
      },
      "RetirementTypeUpdateReqDto": {
        "type": "object",
        "required": ["retirementType"],
        "properties": {
          "retirementType": { "type": "string", "enum": ["DB", "DC"], "description": "퇴직연금 유형 (DB 또는 DC)" }
        }
      },
      "ExpectedDeductionSummaryResDto": {
        "type": "object",
        "properties": {
          "totalEmployees": { "type": "integer", "description": "전체 사원 수" },
          "totalExpectedNetPay": { "type": "integer", "format": "int64", "description": "전체 예상 세후 급여 합계" },
          "employees": {
            "type": "array",
            "description": "사원별 예상 지급/공제 내역",
            "items": { "$ref": "#/components/schemas/ExpectedDeductionResDto" }
          }
        }
      },
      "ExpectedDeductionResDto": {
        "type": "object",
        "properties": {
          "empId": { "type": "integer", "format": "int64", "description": "사원 ID" },
          "empStatus": { "type": "string", "description": "재직상태" },
          "empName": { "type": "string", "description": "사원명" },
          "deptName": { "type": "string", "description": "부서명" },
          "titleName": { "type": "string", "description": "직위명" },
          "annualSalary": { "type": "number", "description": "연봉" },
          "monthlySalary": { "type": "integer", "format": "int64", "description": "월급" },
          "basePay": { "type": "integer", "format": "int64", "description": "기본급" },
          "nationalPension": { "type": "integer", "format": "int64", "description": "국민연금" },
          "healthInsurance": { "type": "integer", "format": "int64", "description": "건강보험" },
          "longTermCare": { "type": "integer", "format": "int64", "description": "장기요양보험" },
          "employmentInsurance": { "type": "integer", "format": "int64", "description": "고용보험" },
          "incomeTax": { "type": "integer", "format": "int64", "description": "소득세" },
          "localIncomeTax": { "type": "integer", "format": "int64", "description": "지방소득세" },
          "totalDeduction": { "type": "integer", "format": "int64", "description": "공제 합계" },
          "expectedNetPay": { "type": "integer", "format": "int64", "description": "예상 세후 월급" }
        }
      }
    }
  }
}
